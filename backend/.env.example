# -------------------------------------------------------
# RetroBoard Backend — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# -------------------------------------------------------

# --- Server ---
PORT=5000
SSL_PORT=5443
NODE_ENV=production

# --- Database (MySQL) ---
DB_HOST=127.0.0.1
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=retro_board

# --- JWT ---
# Must be at least 32 characters. Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret_at_least_32_chars

# --- CORS ---
# Comma-separated list of allowed origins (required in production)
CORS_ORIGINS=https://retroboard.thejumpvault.com

# --- Email (SMTP) ---
# Using Gmail SMTP with the vaultjump.noreply@gmail.com sending account.
# SMTP_PASS must be a Gmail App Password (16 chars, no spaces) generated at
# https://myaccount.google.com/apppasswords (requires 2-Step Verification).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
# Set to 'true' for implicit TLS (usually port 465). If omitted, defaults to true when SMTP_PORT=465.
# SMTP_SECURE=false
# Require STARTTLS upgrade before sending (recommended for Gmail on 587).
SMTP_REQUIRE_TLS=true
SMTP_USER=vaultjump.noreply@gmail.com
SMTP_PASS=your_gmail_app_password
SMTP_FROM="Vault Jump Retro" <vaultjump.noreply@gmail.com>
# Set to 'true' ONLY in local dev with self-signed certs — never in production
SMTP_INSECURE_TLS=false

# --- Password Reset ---
RESET_TOKEN_EXPIRY_MINUTES=30
# Optional emergency fallback key for password reset when SMTP send fails.
# If set, callers may include header x-reset-fallback-key with this value
# to receive resetToken/resetUrl in API response when email delivery fails.
# PASSWORD_RESET_FALLBACK_KEY=replace_with_long_random_value

# --- Giphy ---
GIPHY_API_KEY=your_giphy_api_key

# --- Company / Branding ---
# Default company name used when a user's company field is empty (optional)
# DEFAULT_COMPANY=RetroBoard

# --- Bootstrap Admin / Master Emails (optional) ---
# JSON array of [email, department] pairs — used on first run to seed admins
# DEFAULT_ADMIN_EMAILS=[["admin@example.com","QA"]]
# Comma-separated list of master (super-admin) emails
# DEFAULT_MASTER_EMAILS=master@example.com

# --- Optional: Admin / Master email bootstrap ---
# DEFAULT_ADMIN_EMAILS='[["admin@example.com","QA"]]'
# DEFAULT_MASTER_EMAILS=master@example.com
