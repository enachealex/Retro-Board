<!--
  web.config — IIS configuration for hosting Node.js via iisnode.
  Place this in the backend/ folder alongside server-mssql.js.

  Prerequisites:
    1. Install Node.js on the Windows Server
    2. Install iisnode: https://github.com/Azure/iisnode/releases
    3. Install URL Rewrite Module for IIS: https://www.iis.net/downloads/microsoft/url-rewrite
    4. Create an IIS Site pointing to this backend/ folder
    5. Set the Application Pool to "No Managed Code"
    6. Grant the Application Pool identity read/write on the uploads/ folder
-->
<configuration>
  <system.webServer>

    <!-- iisnode handler — routes all requests through Node.js -->
    <handlers>
      <add name="iisnode" path="server-mssql.js" verb="*" modules="iisnode" />
    </handlers>

    <!-- URL Rewrite: send everything to server-mssql.js except static files -->
    <rewrite>
      <rules>
        <!-- Don't rewrite requests for static upload files -->
        <rule name="StaticUploads" stopProcessing="true">
          <match url="^uploads/(.*)" />
          <action type="Rewrite" url="uploads/{R:1}" />
        </rule>

        <!-- Send all other requests to Node.js -->
        <rule name="NodeJS" stopProcessing="true">
          <match url="(.*)" />
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
          </conditions>
          <action type="Rewrite" url="server-mssql.js" />
        </rule>
      </rules>
    </rewrite>

    <!-- iisnode configuration -->
    <iisnode
      nodeProcessCommandLine="&quot;C:\Program Files\nodejs\node.exe&quot;"
      watchedFiles="*.js;web.config;.env"
      loggingEnabled="true"
      logDirectory="iisnode"
      debuggingEnabled="false"
      maxConcurrentRequestsPerProcess="1024"
      maxNamedPipeConnectionRetry="100"
      namedPipeConnectionRetryDelay="250"
      node_env="production"
    />

    <!-- Allow WebSocket connections (for socket.io) -->
    <webSocket enabled="false" />
    <!-- Note: socket.io uses its own WebSocket upgrade; IIS native WebSocket must be OFF -->

    <!-- Security headers -->
    <httpProtocol>
      <customHeaders>
        <add name="X-Content-Type-Options" value="nosniff" />
        <add name="X-Frame-Options" value="DENY" />
        <add name="X-XSS-Protection" value="1; mode=block" />
      </customHeaders>
    </httpProtocol>

    <!-- Allow large uploads (20MB for GIFs/backgrounds) -->
    <security>
      <requestFiltering>
        <requestLimits maxAllowedContentLength="20971520" />
      </requestFiltering>
    </security>

  </system.webServer>

  <appSettings>
    <!-- Environment variables (can also be set in .env or IIS App Settings) -->
    <!-- <add key="DB_HOST" value="your-sql-server" /> -->
    <!-- <add key="DB_USER" value="sa" /> -->
    <!-- <add key="DB_PASSWORD" value="" /> -->
    <!-- <add key="DB_NAME" value="retro_board" /> -->
    <!-- <add key="JWT_SECRET" value="your-secret" /> -->
  </appSettings>
</configuration>
