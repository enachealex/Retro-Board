# Vite dev proxy target — the backend server to proxy API/WebSocket/upload requests to.
# Default: http://localhost:5000 (local backend)
# Set this to hit a remote backend during development.
VITE_API_TARGET=http://localhost:5000

# hCaptcha site key (public) — must match backend HCAPTCHA_SITE_KEY
VITE_HCAPTCHA_SITE_KEY=7f02f2f0-347c-46aa-a026-61ae184ef028

# Branding (optional)
# VITE_APP_NAME=Jump Vault Retro
# VITE_COMPANY_NAME=The Jump Vault

# Do not set backend fallback verification secrets in frontend env files.
