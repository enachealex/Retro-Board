# Vite dev proxy target — the backend server to proxy API/WebSocket/upload requests to.
# Default: http://localhost:5000 (local backend)
# Set this to hit a remote backend during development.
VITE_API_TARGET=http://localhost:5000

# Optional: manual email verification fallback key for local testing only.
# If set, the frontend sends header x-verify-fallback-key on register/resend requests.
# Must match backend EMAIL_VERIFICATION_FALLBACK_KEY.
# VITE_EMAIL_VERIFICATION_FALLBACK_KEY=replace_with_same_backend_value
